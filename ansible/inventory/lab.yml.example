---
# Copy to inventory/lab.yml and fill IPs from `terraform output`.

all:
  vars:
    ansible_user: root
    ansible_ssh_private_key_file: ~/.ssh/id_rsa  # pre-staged on the bastion
    cluster_name: sno
    cluster_base_domain: lab.local

  children:
    # Bastion runs Ansible against itself (local connection) for DNS setup.
    bastion:
      hosts:
        bastion-local:
          ansible_connection: local
          ansible_host: 127.0.0.1

    sno:
      hosts:
        sno-node:
          ansible_host: PLACEHOLDER_SNO_PRIVATE_IP  # terraform output sno_private_ip

    nfs:
      hosts:
        nfs-server:
          ansible_host: PLACEHOLDER_NFS_PRIVATE_IP  # terraform output nfs_private_ip
      vars:
        nfs_export_path: /srv/nfs/openshift
        nfs_export_size_gb: 400
        nfs_allowed_cidr: PLACEHOLDER_SUBNET_CIDR   # terraform output subnet_cidr
