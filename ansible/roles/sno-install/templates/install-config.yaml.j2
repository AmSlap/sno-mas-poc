apiVersion: v1
baseDomain: {{ cluster_base_domain }}
metadata:
  name: {{ cluster_name }}

# SNO topology: one control-plane node, zero compute nodes. The same node
# runs API, etcd, ingress, and workloads.
controlPlane:
  name: master
  replicas: 1
compute:
  - name: worker
    replicas: 0

networking:
  clusterNetwork:
    - cidr: {{ cluster_network_cidr }}
      hostPrefix: 23
  serviceNetwork:
    - {{ service_network_cidr }}
  machineNetwork:
    - cidr: {{ machine_network_cidr }}
  networkType: OVNKubernetes

platform:
  none: {}

bootstrapInPlace:
  installationDisk: /dev/vda  # adjust if IBM Cloud VPC exposes a different block device

pullSecret: '{{ lookup("file", pull_secret_path) }}'
sshKey: |
  {{ lookup("file", "~/.ssh/lab-key.pub") }}
