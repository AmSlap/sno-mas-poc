# Copy to terraform.tfvars and fill in. DO NOT commit terraform.tfvars.
# Prefer passing credentials via env vars (TF_VAR_ibmcloud_iam_token) to keep
# them out of the file entirely.

# ---- Credentials ----
# Provide EXACTLY ONE of the two below. Leave the other empty.

# Option A: long-lived API key
ibmcloud_api_key = ""

# Option B: short-lived IAM Bearer token (session-based auth).
# If you use this, prefer setting it via env var instead — see README.
# Refresh procedure: `ibmcloud login --sso -c <account_id>` then
# `ibmcloud iam oauth-tokens | awk '/IAM token/ {print $4}'`
ibmcloud_iam_token  = ""
ibmcloud_account_id = "3021e28c09a04c09ae6b1f843606cfdd"

# ---- IBM Cloud context ----
region              = "eu-gb"
resource_group_name = "Default"
vpc_name            = "itz-vpc-02"
subnet_name         = "sn01"

# ---- Derived from bastion reconnaissance ----
ssh_public_key_path = "~/.ssh/id_rsa.pub"
bastion_subnet_cidr = "10.251.128.0/24"

# ---- Defaults (safe to keep) ----
rhel_image_name     = "ibm-redhat-9-6-amd64-1"
cluster_base_domain = "lab.local"
cluster_name        = "sno"
